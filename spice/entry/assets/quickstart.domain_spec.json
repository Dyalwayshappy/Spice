        "operation": "service.monitor",
        "parameters": {
          "scope": "service"
        },
        "type": "mock"
      },
      "expected_outcome_type": "quickstart.service_ops.transition",
      "id": "quickstart.service_ops.monitor"
    },
    {
      "description": "Notify operator channel.",
      "executor": {
        "operation": "service.notify",
        "parameters": {
          "channel": "ops"
        },
        "type": "mock"
      },
      "expected_outcome_type": "quickstart.service_ops.transition",
      "id": "quickstart.service_ops.notify"
    }
  ],
  "decision": {
