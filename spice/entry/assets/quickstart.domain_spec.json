        "type": "quickstart.service_ops.alert_opened"
      },
      {
        "attributes": {
          "error_rate": 0.06,
          "severity": "high",
          "status": "monitoring"
        },
        "source": "quickstart.demo",
        "type": "quickstart.service_ops.metric_snapshot"
      }
    ]
  },
  "domain": {
